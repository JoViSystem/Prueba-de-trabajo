function render() {
    let tabla = document.getElementById("tabla");
    let tablaHistorial = document.getElementById("tablaHistorial");
    if(!tabla) return;
    tabla.innerHTML = ""; tablaHistorial.innerHTML = "";

    let horasDiaActividades = 0, okDia = 0, conteoActividadesDia = 0, pendientesDia = 0;
    let filtro = getFiltroUsuario();
    let filtroDia = document.getElementById("filtroCalendarioDia").value;
    let hoyStr = obtenerFechaHoyLocal();

    let indicadorDashboard = document.getElementById("dashboard-date-indicator");
    if(indicadorDashboard) {
        if (filtroDia === hoyStr) {
            indicadorDashboard.innerText = `⏱️ Mostrando métricas del día de hoy (${filtroDia})`;
        } else if (filtroDia) {
            indicadorDashboard.innerText = `🔍 Trazabilidad activa para el día: ${filtroDia}`;
        } else {
            indicadorDashboard.innerText = `📋 Mostrando acumulado histórico total`;
        }
    }

    actividades.forEach((a, i) => {
        if (!a.usuario) a.usuario = "DCumplimiento";
        if (usuarioActivo.rol === "supervisor" && a.usuario === "DCumplimiento") return;
        if (filtro !== "todos" && a.usuario !== filtro) return;

        let coincideConFechaFiltro = (!filtroDia || a.fecha === filtroDia);

        if (coincideConFechaFiltro) {
            horasDiaActividades += a.horas;
            conteoActividadesDia++;
            if(a.estado === "Completada") okDia++;
            if(a.estado === "Pendiente" || a.estado === "En proceso") pendientesDia++;
        }

        let claseEstado = a.estado === "Pendiente" ? "badge-rojo" : a.estado === "En proceso" ? "badge-amarillo" : "badge-verde";
        let deshabilitarSelect = (usuarioActivo.rol !== "admin" && a.usuario !== usuarioActivo.username) ? "disabled" : "";
        let nombreDisplay = USUARIOS_VALIDOS[a.usuario] ? USUARIOS_VALIDOS[a.usuario].nombre : "Desconocido";

        if (coincideConFechaFiltro) {
            tabla.innerHTML += `
            <tr>
                <td style="font-weight:600;">👤 ${nombreDisplay}</td>
                <td>${a.titulo}</td>
                <td><span style="background:#f1f5f9; padding:4px 8px; border-radius:6px; font-size:13px;">${a.categoria}</span></td>
                <td>📅 ${a.fecha}</td>
                <td style="font-weight:600;">⏱️ ${a.horas.toFixed(2)}h</td>
                <td>
                    <select class="${claseEstado}" onchange="cambiarEstadoActividad(${i}, this.value)" ${deshabilitarSelect}>
                        <option value="Pendiente" ${a.estado === "Pendiente" ? "selected" : ""}>⚠️ Pendiente</option>
                        <option value="En proceso" ${a.estado === "En proceso" ? "selected" : ""}>🔄 En proceso</option>
                        <option value="Completada" ${a.estado === "Completada" ? "selected" : ""}>✅ Completada</option>
                    </select>
                </td>
                <td><button class="btn-delete" onclick="eliminarActividad(${i})" ${deshabilitarSelect}>🗑️ Borrar</button></td>
            </tr>`;
        }

        tablaHistorial.innerHTML += `
        <tr>
            <td>👤 ${nombreDisplay}</td><td>${a.titulo}</td><td>${a.categoria}</td><td>${a.fecha}</td><td>${a.horas.toFixed(2)}h</td>
            <td><span class="${claseEstado}">${a.estado}</span></td>
        </tr>`;
    });

    let horasDiaAsociados = 0;
    let conteoAsociadosDia = 0;
    asociados.forEach(asoc => {
        if (!asoc.usuario) asoc.usuario = "DCumplimiento";
        if (usuarioActivo.rol === "supervisor" && asoc.usuario === "DCumplimiento") return;
        if (filtro !== "todos" && asoc.usuario !== filtro) return;

        if (!filtroDia || asoc.fecha === filtroDia) {
            horasDiaAsociados += (asoc.horas || 0);
            conteoAsociadosDia++;
        }
    });

    let granTotalHorasDia = horasDiaActividades + horasDiaAsociados;
    let granTotalCargaObjetos = conteoActividadesDia + conteoAsociadosDia;

    let reportesAbiertosConteo = reportes.filter(r => {
        if (usuarioActivo.rol === "supervisor" && r.usuario === "DCumplimiento") return false;
        if (filtro !== "todos" && r.usuario !== filtro) return false;
        return r.estado === "Abierto" || r.estado === "En proceso";
    }).length;

    document.getElementById("total").innerText = granTotalCargaObjetos;
    document.getElementById("horas").innerText = granTotalHorasDia.toFixed(2) + " hrs";
    document.getElementById("cumplimiento").innerText = conteoActividadesDia ? (okDia / conteoActividadesDia * 100).toFixed(0) + "%" : "100%";
    document.getElementById("dash-pendientes").innerText = pendientesDia;
    document.getElementById("dash-reportes").innerText = reportesAbiertosConteo;
    
    localStorage.setItem("act", JSON.stringify(actividades));
}

