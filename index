document.getElementById("actividadForm").onsubmit = function(e) {
    e.preventDefault();
    let h1 = document.getElementById("hora_inicio").value.split(":"); 
    let h2 = document.getElementById("hora_fin").value.split(":");
    let horas = (parseInt(h2[0]) + h2[1]/60) - (parseInt(h1[0]) + h1[1]/60);
    if (horas < 0) { alert("La hora de fin debe ser posterior al inicio."); return; }

    let asignadoA = document.getElementById("asignar_a").value || usuarioActivo.username;
    let fechaBaseStr = document.getElementById("fecha").value; 
    let frec = document.getElementById("frecuencia").value;
    let tituloVal = document.getElementById("titulo").value;
    let catVal = document.getElementById("categoria").value;
    let estVal = document.getElementById("estado").value;

    if (frec === "unica") {
        actividades.push({ usuario: asignadoA, titulo: tituloVal, categoria: catVal, fecha: fechaBaseStr, horas: horas, estado: estVal });
    } 
    else if (frec === "diaria") {
        let dateObj = new Date(fechaBaseStr + "T00:00:00");
        for (let d = 0; d < 7; d++) {
            let yyyy = dateObj.getFullYear();
            let mm = String(dateObj.getMonth() + 1).padStart(2, '0');
            let dd = String(dateObj.getDate()).padStart(2, '0');
            let nuevaFecha = `${yyyy}-${mm}-${dd}`;
            
            actividades.push({ usuario: asignadoA, titulo: `${tituloVal} (Día ${d+1}/7)`, categoria: catVal, fecha: nuevaFecha, horas: horas, estado: estVal });
            dateObj.setDate(dateObj.getDate() + 1);
        }
    } 
    else if (frec === "mensual") {
        let dateObj = new Date(fechaBaseStr + "T00:00:00");
        for (let m = 0; m < 3; m++) {
            let yyyy = dateObj.getFullYear();
            let mm = String(dateObj.getMonth() + 1).padStart(2, '0');
            let dd = String(dateObj.getDate()).padStart(2, '0');
            let nuevaFecha = `${yyyy}-${mm}-${dd}`;

            actividades.push({ usuario: asignadoA, titulo: `${tituloVal} (Mes ${m+1}/3)`, categoria: catVal, fecha: nuevaFecha, horas: horas, estado: estVal });
            dateObj.setMonth(dateObj.getMonth() + 1);
        }
    }

    document.getElementById("actividadForm").reset(); 
    ejecutarFiltroGlobal();
};

